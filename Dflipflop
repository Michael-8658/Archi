library ieee;
use ieee.std_logic_1164.all;

entity Dff is
port (d, clk, clr : in std_logic;
      q : out std_logic);
end Dff;

architecture behavior of Dff is
begin
process(clk, clr)
begin
    if clr = '1' then
        q <= '0';
    elsif rising_edge(clk) then
        q <= d;
    end if;
end process;
end behavior;
