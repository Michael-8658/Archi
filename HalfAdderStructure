library ieee; 
use ieee.std_logic_1164.all;

entity half_adder is
	port(x,y:in std_logic;sum,carry:out std_logic);
end half_adder;

architecture structure of half_adder is
        signal s1,s2:std_logic;

	begin
		s1<=x and y;
                carry<=s1;
                s2<= x xor y;
		sum<=s2;


	end structure;
